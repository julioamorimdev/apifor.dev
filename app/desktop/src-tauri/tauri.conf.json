{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "apifor",
  "version": "0.1.0",
  "identifier": "dev.apifor.desktop",
  "build": {
    "frontendDist": "../../dashboard/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../../dashboard && npm run dev",
    "beforeBuildCommand": "cd ../../dashboard && NEXT_EXPORT=1 NEXT_PUBLIC_API_BASE=$APIFOR_CEREBRO_URL npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "apifor.dev",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "shortDescription": "Orquestrador de workers de IA que escrevem código",
    "longDescription": "apifor.dev — fila de tarefas, workers locais, PR, CI/QA, merge. Chaves e código nunca saem da sua máquina."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.apifor.dev/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBKEY"
    }
  }
}
